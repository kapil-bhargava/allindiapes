{
    "version": 2,
    "buildCommand": "npm run build",
    "devCommand": "npm run dev",
    "installCommand": "npm install",
    "framework": "vite",
    "outputDirectory": "dist",
    "routes": [
        {
            "src": "/",
            "dest": "/index.html"
        },
        {
            "src": "/about",
            "dest": "/index.html"
        },
        {
            "src": "/contact",
            "dest": "/index.html"
        },
        {
            "src": "/team",
            "dest": "/index.html"
        },
        {
            "src": "/patrakars",
            "dest": "/index.html"
        },
        {
            "src": "/privacy",
            "dest": "/index.html"
        },
        {
            "src": "/terms",
            "dest": "/index.html"
        },
        {
            "src": "/help",
            "dest": "/index.html"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                }
            ]
        },
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "github": {
        "enabled": false,
        "silent": true
    }
}